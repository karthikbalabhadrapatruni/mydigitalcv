# Required for the Python portfolio agent service
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: override the Gemini model used by the portfolio AI assistant
GEMINI_MODEL=gemini-2.5-flash

# Required for the Next.js proxy route to reach the Python backend
PORTFOLIO_AGENT_API_URL=http://127.0.0.1:8000

# Optional: comma-separated origins allowed by the Python backend
PYTHON_AGENT_ALLOWED_ORIGINS=http://localhost:3000

# Optional: useful for metadata, links, and production deployment setup
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: keep contact details configurable instead of hardcoding them
CONTACT_EMAIL=karthik.bmk3@gmail.com
